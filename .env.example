# ═══════════════════════════════════════════════════════════════════════
# Signal AI Agent — Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# MODE: uncomment ONE URL pair below (Docker OR Host).
# The scripts/run-host.sh and scripts/run-docker.sh handle this
# automatically, but you can also toggle manually.
# ═══════════════════════════════════════════════════════════════════════

# ── Docker mode (bot runs in container) ──────────────────────────────
# Use these when running via: ./scripts/up.sh
#LLM_BASE_URL=http://host.docker.internal:1234/v1
#SIGNAL_API_URL=http://signal-api:8080

# ── Host mode (bot runs directly on macOS/Linux) ─────────────────────
# Use these when running via: ./scripts/run-host.sh
LLM_BASE_URL=http://localhost:1234/v1
SIGNAL_API_URL=http://localhost:9922

# ── LLM settings ─────────────────────────────────────────────────────
LLM_API_KEY=lm-studio
LLM_MODEL=qwen2.5-14b-instruct
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Signal ────────────────────────────────────────────────────────────
# Your bot's Signal phone number in international format
SIGNAL_NUMBER=+1234567890

# Optional: restrict who can message the bot (comma-separated)
# ALLOWED_NUMBERS=+14155551234,+14155559999

# ── Audio service (STT + TTS) ─────────────────────────────────────────
# Remote OpenAI-compatible audio service for voice transcription and TTS synthesis.
# Point at your own Whisper/Kokoro deployment (e.g. audio-api from local-ai-stack).
#AUDIO_API_URL=http://audio-api:8088     # Docker mode
AUDIO_API_URL=http://localhost:8088      # Host mode

# ── TTS (voice replies, optional) ────────────────────────────────────
# Kokoro TTS — synthesizes a voice note reply when you send a voice message.
# Voices: af_heart (warm female EN), af_bella, am_adam, am_michael, bf_emma, bm_george
# Lang codes: a=en-US, b=en-GB
TTS_ENABLED=true
TTS_VOICE=af_heart
TTS_LANG=a
TTS_SPEED=1.0

# ── Long-term memory (optional) ──────────────────────────────────────
# memory-mcp REST API (Mem0 + bge-m3 + Qdrant). Leave blank to disable.
#MEMORY_MCP_URL=http://memory-mcp:8089   # Docker mode
#MEMORY_DIR_MOUNT=/memory               # Path to SOUL.md / USER.md / MEMORY.md
#MEMORY_DEFAULT_USER_ID=default
#MEMORY_HTTP_TIMEOUT=5.0

# ── Group behavior ────────────────────────────────────────────────────
# Who can use privileged commands (/memory) in group chats.
# Set to your own Signal number in international format.
#BRIEFING_RECIPIENT=+1234567890

# ── FreshRSS (optional, for RSS digest skill) ────────────────────────
# FRESHRSS_URL=http://192.168.0.122:17406
# FRESHRSS_USER=admin
# FRESHRSS_API_PASSWORD=your-api-password

# ── Group behavior ────────────────────────────────────────────────────
# Text prefix that triggers the bot in group chats (case-insensitive).
# The portion after the leading @ is also used as the voice wake-word.
BOT_GROUP_PREFIX=@bot
